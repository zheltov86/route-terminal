#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОписаниеПеременных

Перем ЛогЗагрузки;

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Загружает данные из XML-файла EnterpriseData 1.8 через XDTO.
// Создаёт документ "Заказ клиента" с проведением.
//
// Параметры:
//   ИмяФайла - Строка - полный путь к XML-файлу.
//
// Возвращаемое значение:
//   Структура - Успех, Сообщение, КоличествоСоздано.
//
Функция ЗагрузитьДанныеИзФайла(ИмяФайла = "D:\DATA\Export_RouteTerminal.xml") Экспорт
	
	Результат = Новый Структура("Успех, Сообщение, КоличествоСоздано", Ложь, "", 0);
	ИнициализироватьЛог();
	
	ФайлXML = Новый Файл(ИмяФайла);
	Если Не ФайлXML.Существует() Тогда
		Результат.Сообщение = СтрШаблон("Файл не найден: %1", ИмяФайла);
		ДобавитьВЛог("ОШИБКА", "", Результат.Сообщение);
		Возврат Результат;
	КонецЕсли;
	
	Попытка
		ТекстовыйДокумент = Новый ТекстовыйДокумент;
		ТекстовыйДокумент.Прочитать(ИмяФайла, КодировкаТекста.UTF8);
		ТекстXML = ТекстовыйДокумент.ПолучитьТекст();
	Исключение
		Результат.Сообщение = СтрШаблон("Ошибка чтения файла: %1", ОписаниеОшибки());
		ДобавитьВЛог("ОШИБКА", "", Результат.Сообщение);
		Возврат Результат;
	КонецПопытки;
	
	Попытка
		РезультатЗагрузки = ЗагрузитьДанныеИзXML_XDTO(ТекстXML);
		Результат.Успех = Истина;
		Результат.Сообщение = СтрШаблон("Загрузка завершена. Создано документов: %1", 
			РезультатЗагрузки.КоличествоСоздано);
		Результат.КоличествоСоздано = РезультатЗагрузки.КоличествоСоздано;
	Исключение
		Результат.Сообщение = СтрШаблон("Ошибка загрузки: %1", ОписаниеОшибки());
		ДобавитьВЛог("ОШИБКА", "", Результат.Сообщение);
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

// Загружает данные через web-сервис (HTTP GET) и создаёт документы "Заказ клиента".
// Использует XDTO для парсинга EnterpriseData 1.8 XML.
//
// Параметры:
//   URLАдрес - Строка - URL web-сервиса.
//
// Возвращаемое значение:
//   Структура - Успех, Сообщение, КоличествоСоздано.
//
Функция ЗагрузитьДанныеИзWebСервиса(URLАдрес) Экспорт
	
	Результат = Новый Структура("Успех, Сообщение, КоличествоСоздано", Ложь, "", 0);
	ИнициализироватьЛог();
	
	Попытка
		СтруктураURL = РазобратьURL(URLАдрес);
		Соединение = Новый HTTPСоединение(
			СтруктураURL.Сервер, СтруктураURL.Порт, , , , 30);
		Запрос = Новый HTTPЗапрос(СтруктураURL.Путь);
		Ответ = Соединение.ВызватьHTTPМетод("GET", Запрос);
		
		Если Ответ.КодСостояния <> 200 Тогда
			Результат.Сообщение = СтрШаблон("Ошибка HTTP: код %1", Ответ.КодСостояния);
			ДобавитьВЛог("ОШИБКА", "", Результат.Сообщение);
			Возврат Результат;
		КонецЕсли;
		
		ТелоОтвета = Ответ.ПолучитьТелоКакСтроку();
	Исключение
		Результат.Сообщение = СтрШаблон("Ошибка соединения: %1", ОписаниеОшибки());
		ДобавитьВЛог("ОШИБКА", "", Результат.Сообщение);
		Возврат Результат;
	КонецПопытки;
	
	Попытка
		РезультатЗагрузки = ЗагрузитьДанныеИзXML_XDTO(ТелоОтвета);
		Результат.Успех = Истина;
		Результат.Сообщение = СтрШаблон("Загрузка завершена. Создано документов: %1", 
			РезультатЗагрузки.КоличествоСоздано);
		Результат.КоличествоСоздано = РезультатЗагрузки.КоличествоСоздано;
	Исключение
		Результат.Сообщение = СтрШаблон("Ошибка обработки XML: %1", ОписаниеОшибки());
		ДобавитьВЛог("ОШИБКА", "", Результат.Сообщение);
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

// Возвращает таблицу лога загрузки.
//
Функция ПолучитьЛог() Экспорт
	Возврат ЛогЗагрузки;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ИнициализироватьЛог()
	ЛогЗагрузки = Новый ТаблицаЗначений;
	ЛогЗагрузки.Колонки.Добавить("Дата",      Новый ОписаниеТипов("Дата"));
	ЛогЗагрузки.Колонки.Добавить("Статус",    Новый ОписаниеТипов("Строка",,, Новый КвалификаторыСтроки(20)));
	ЛогЗагрузки.Колонки.Добавить("Объект",    Новый ОписаниеТипов("Строка",,, Новый КвалификаторыСтроки(200)));
	ЛогЗагрузки.Колонки.Добавить("Сообщение", Новый ОписаниеТипов("Строка"));
КонецПроцедуры

Процедура ДобавитьВЛог(Статус, Объект, Сообщение)
	НоваяСтрока = ЛогЗагрузки.Добавить();
	НоваяСтрока.Дата      = ТекущаяДатаСеанса();
	НоваяСтрока.Статус    = Статус;
	НоваяСтрока.Объект    = Объект;
	НоваяСтрока.Сообщение = Сообщение;
КонецПроцедуры
// XDTO SAX-парсинг EnterpriseData 1.8
// Алгоритм: BSP ОбменДаннымиXDTOСервер

Функция ЗагрузитьДанныеИзXML_XDTO(ТекстXML)
	
	Результат = Новый Структура("КоличествоСоздано", 0);
	URI_ED = "http://v8.1c.ru/edi/edi_stnd/EnterpriseData/1.8";
	
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(ТекстXML);
	
	// Message
	ЧтениеXML.Прочитать();
	Если ЧтениеXML.ЛокальноеИмя <> "Message" Тогда
		ДобавитьВЛог("ОШИБКА", "", "Ожидается элемент Message");
		Возврат Результат;
	КонецЕсли;
	
	// Header
	ЧтениеXML.Прочитать();
	Если ЧтениеXML.ЛокальноеИмя = "Header" Тогда
		ЧтениеXML.Пропустить();
	КонецЕсли;
	
	// Body
	ЧтениеXML.Прочитать();
	Если ЧтениеXML.ЛокальноеИмя <> "Body" Тогда
		ДобавитьВЛог("ОШИБКА", "", "Ожидается элемент Body");
		Возврат Результат;
	КонецЕсли;
	
	// SAX-цикл по элементам Body
	Пока ЧтениеXML.Прочитать() Цикл
		Если ЧтениеXML.ТипУзла = ТипУзлаXML.КонецЭлемента
			И ЧтениеXML.ЛокальноеИмя = "Body" Тогда
			Прервать;
		КонецЕсли;
		Если ЧтениеXML.ТипУзла <> ТипУзлаXML.НачалоЭлемента Тогда
			Продолжить;
		КонецЕсли;
		ИмяЭлемента = ЧтениеXML.ЛокальноеИмя;
		Попытка
			ТипОбъектаXDTO = ФабрикаXDTO.Тип(URI_ED, ИмяЭлемента);
			Если ТипОбъектаXDTO = Неопределено Тогда
				ДобавитьВЛог("ПРОПУЩЕН", ИмяЭлемента, "Тип не найден");
				ЧтениеXML.Пропустить();
				Продолжить;
			КонецЕсли;
			ОбъектXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML, ТипОбъектаXDTO);
		Исключение
			ДобавитьВЛог("ОШИБКА", ИмяЭлемента, "Ошибка XDTO: " + ОписаниеОшибки());
			Продолжить;
		КонецПопытки;
		Если ИмяЭлемента = "Справочник.Валюты" Тогда
			ОбработатьВалюту(ОбъектXDTO);
		ИначеЕсли ИмяЭлемента = "Справочник.Организации" Тогда
			ОбработатьОрганизацию(ОбъектXDTO);
		ИначеЕсли ИмяЭлемента = "Справочник.Контрагенты" Тогда
			ОбработатьКонтрагента(ОбъектXDTO);
		ИначеЕсли ИмяЭлемента = "Документ.ЗаказКлиента" Тогда
			СоздатьЗаказКлиента(ОбъектXDTO, URI_ED);
			Результат.КоличествоСоздано = Результат.КоличествоСоздано + 1;
		Иначе
			ДобавитьВЛог("ПРОПУЩЕН", ИмяЭлемента, "Неизвестный тип");
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

Процедура ОбработатьВалюту(ОбъектXDTO)
	Попытка
		КС = ОбъектXDTO.КлючевыеСвойства;
		Наименование = "";
		ДК = КС.Свойства().Получить("ДанныеКлассификатора");
		Если ДК <> Неопределено Тогда Наименование = Строка(КС.ДанныеКлассификатора.Наименование); КонецЕсли;
		Если Не ЗначениеЗаполнено(Наименование) Тогда Наименование = "руб."; КонецЕсли;
		Найденная = Справочники.Валюты.НайтиПоНаименованию(Наименование);
		Если ЗначениеЗаполнено(Найденная) Тогда
			ДобавитьВЛог("НАЙДЕН", Строка(Найденная), "Валюта: " + Наименование);
		Иначе
			НоваяВалюта = Справочники.Валюты.СоздатьЭлемент();
			НоваяВалюта.Наименование = Наименование;
			Если ДК <> Неопределено Тогда НоваяВалюта.Код = Строка(КС.ДанныеКлассификатора.Код); КонецЕсли;
			НоваяВалюта.Записать();
			ДобавитьВЛог("СОЗДАН", Строка(НоваяВалюта.Ссылка), "Валюта: " + Наименование);
		КонецЕсли;
	Исключение
		ДобавитьВЛог("ОШИБКА", "", "Ошибка валюты: " + ОписаниеОшибки());
	КонецПопытки;
КонецПроцедуры

Процедура ОбработатьОрганизацию(ОбъектXDTO)
	Попытка
		КС = ОбъектXDTO.КлючевыеСвойства;
		Наименование = Строка(КС.Наименование);
		Если Не ЗначениеЗаполнено(Наименование) Тогда ДобавитьВЛог("ОШИБКА", "", "Организация: пустое Наименование"); Возврат; КонецЕсли;
		Найденная = Справочники.Организации.НайтиПоНаименованию(Наименование);
		Если ЗначениеЗаполнено(Найденная) Тогда
			ДобавитьВЛог("НАЙДЕН", Строка(Найденная), "Организация: " + Наименование);
		Иначе
			НоваяОрг = Справочники.Организации.СоздатьЭлемент();
			НоваяОрг.Наименование = Наименование;
			НоваяОрг.НаименованиеПолное = Наименование;
			НоваяОрг.НаименованиеСокращенное = Наименование;
			ИНН = ?(КС.Свойства().Получить("ИНН") <> Неопределено, Строка(КС.ИНН), "");
			КПП = ?(КС.Свойства().Получить("КПП") <> Неопределено, Строка(КС.КПП), "");
			НоваяОрг.ИНН = ИНН; НоваяОрг.КПП = КПП;
			НоваяОрг.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ЮридическоеЛицо;
			Если Не НоваяОрг.ПроверитьЗаполнение() Тогда ДобавитьВЛог("ОШИБКА", "", "Организация: проверка не пройдена"); Возврат; КонецЕсли;
			НоваяОрг.Записать();
			ДобавитьВЛог("СОЗДАН", Строка(НоваяОрг.Ссылка), "Организация: " + Наименование + " ИНН=" + ИНН);
		КонецЕсли;
	Исключение
		ДобавитьВЛог("ОШИБКА", "", "Ошибка организации: " + ОписаниеОшибки());
	КонецПопытки;
КонецПроцедуры

Процедура ОбработатьКонтрагента(ОбъектXDTO)
	Попытка
		КС = ОбъектXDTO.КлючевыеСвойства;
		Наименование = Строка(КС.Наименование);
		Если Не ЗначениеЗаполнено(Наименование) Тогда ДобавитьВЛог("ОШИБКА", "", "Контрагент: пустое Наименование"); Возврат; КонецЕсли;
		Найденный = Справочники.Контрагенты.НайтиПоНаименованию(Наименование, Истина);
		Если Не ЗначениеЗаполнено(Найденный) Тогда
			НовыйКонтр = Справочники.Контрагенты.СоздатьЭлемент();
			НовыйКонтр.Наименование = Наименование;
			ПолноеНаим = ?(КС.Свойства().Получить("НаименованиеПолное") <> Неопределено, Строка(КС.НаименованиеПолное), Наименование);
			НовыйКонтр.НаименованиеПолное = ПолноеНаим;
			ЮЛ = ?(КС.Свойства().Получить("ЮридическоеФизическоеЛицо") <> Неопределено, Строка(КС.ЮридическоеФизическоеЛицо), "ЮридическоеЛицо");
			НовыйКонтр.ЮридическоеФизическоеЛицо = ?(ЮЛ = "ФизическоеЛицо", Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо, Перечисления.ЮридическоеФизическоеЛицо.ЮридическоеЛицо);
			Если Не НовыйКонтр.ПроверитьЗаполнение() Тогда ДобавитьВЛог("ОШИБКА", "", "Контрагент: проверка не пройдена"); Возврат; КонецЕсли;
			НовыйКонтр.Записать();
			ДобавитьВЛог("СОЗДАН", Строка(НовыйКонтр.Ссылка), "Контрагент: " + Наименование);
		Иначе
			ДобавитьВЛог("НАЙДЕН", Строка(Найденный), "Контрагент: " + Наименование);
		КонецЕсли;
	Исключение
		ДобавитьВЛог("ОШИБКА", "", "Ошибка контрагента: " + ОписаниеОшибки());
	КонецПопытки;
КонецПроцедуры

// Создание документа ЗаказКлиента
// ══════════════════════════════════════════════

Процедура СоздатьЗаказКлиента(ДокументXDTO, URI_ED)
	
	КС = ДокументXDTO.КлючевыеСвойства;
	Номер = Строка(КС.Номер);
	ДатаСтрока = Строка(КС.Дата);
	
	// Парсинг даты
	Попытка
		ДатаЗаказа = Дата(Лев(ДатаСтрока, 4), Сред(ДатаСтрока, 6, 2), Сред(ДатаСтрока, 9, 2));
	Исключение
		ДатаЗаказа = ТекущаяДатаСеанса();
	КонецПопытки;
	
	// Проверка на дубли
	Если ЗначениеЗаполнено(Номер) Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ ПЕРВЫЕ 1 ЗаказКлиента.Ссылка
			|ИЗ Документ.ЗаказКлиента КАК ЗаказКлиента
			|ГДЕ ЗаказКлиента.Номер = &Номер
			|И НАЧАЛОПЕРИОДА(ЗаказКлиента.Дата, ДЕНЬ) = НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ)";
		Запрос.УстановитьПараметр("Номер", Номер);
		Запрос.УстановитьПараметр("Дата", ДатаЗаказа);
		РезультатЗапроса = Запрос.Выполнить();
		Если Не РезультатЗапроса.Пустой() Тогда
			ДобавитьВЛог("ПРОПУЩЕН", "", СтрШаблон("Дубль: %1 от %2", Номер, Формат(ДатаЗаказа, "ДФ=dd.MM.yyyy")));
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	НачатьТранзакцию();
	Попытка
		
		ЗаказОбъект = Документы.ЗаказКлиента.СоздатьДокумент();
		ЗаказОбъект.Дата = ДатаЗаказа;
		ЗаказОбъект.Номер = Номер;
		
		// ═══ Заполнение шапки ═══
		
		// Организация
		ОргXDTO = ДокументXDTO.Свойства().Получить("Организация");
		Если ОргXDTO <> Неопределено Тогда
			НаименованиеОрг = Строка(ДокументXDTO.Организация.Наименование);
			НайденнаяОрг = Справочники.Организации.НайтиПоНаименованию(НаименованиеОрг);
			Если ЗначениеЗаполнено(НайденнаяОрг) Тогда
				ЗаказОбъект.Организация = НайденнаяОрг;
			Иначе
				// Автосоздание организации
				НоваяОрг = Справочники.Организации.СоздатьЭлемент();
				НоваяОрг.Наименование = НаименованиеОрг;
				НоваяОрг.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ЮридическоеЛицо;
				НоваяОрг.Записать();
				ЗаказОбъект.Организация = НоваяОрг.Ссылка;
				ДобавитьВЛог("СОЗДАН", Строка(НоваяОрг.Ссылка), "Организация из заказа: " + НаименованиеОрг);
			КонецЕсли;
		КонецЕсли;
		
		// Если организация не заполнена — подставляем нашу
		Если Не ЗначениеЗаполнено(ЗаказОбъект.Организация) Тогда
			НашаОрганизация = Справочники.Организации.НайтиПоНаименованию("Управленческая организация");
			Если ЗначениеЗаполнено(НашаОрганизация) Тогда
				ЗаказОбъект.Организация = НашаОрганизация;
			Иначе
				ЗаказОбъект.Организация = Справочники.Организации.ОсновнаяОрганизация();
			КонецЕсли;
			ДобавитьВЛог("УСТАНОВЛЕН", "", "Организация по умолчанию: " + Строка(ЗаказОбъект.Организация));
		КонецЕсли;
		
		// Контрагент
		КонтрXDTO = ДокументXDTO.Свойства().Получить("Контрагент");
		Если КонтрXDTO <> Неопределено Тогда
			НаименованиеКонтр = Строка(ДокументXDTO.Контрагент.Наименование);
			НайденныйКонтр = Справочники.Контрагенты.НайтиПоНаименованию(НаименованиеКонтр, Истина);
			Если ЗначениеЗаполнено(НайденныйКонтр) Тогда
				ЗаказОбъект.Контрагент = НайденныйКонтр;
			Иначе
				НовыйКонтр = Справочники.Контрагенты.СоздатьЭлемент();
				НовыйКонтр.Наименование = НаименованиеКонтр;
				НовыйКонтр.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ЮридическоеЛицо;
				НовыйКонтр.Записать();
				ЗаказОбъект.Контрагент = НовыйКонтр.Ссылка;
				ДобавитьВЛог("СОЗДАН", Строка(НовыйКонтр.Ссылка), "Контрагент: " + НаименованиеКонтр);
			КонецЕсли;
		КонецЕсли;
		
		// Валюта
		ВалютаXDTO = ДокументXDTO.Свойства().Получить("Валюта");
		Если ВалютаXDTO <> Неопределено Тогда
			НаименованиеВалюты = Строка(ДокументXDTO.Валюта.Наименование);
			НайденнаяВалюта = Справочники.Валюты.НайтиПоНаименованию(НаименованиеВалюты);
			Если ЗначениеЗаполнено(НайденнаяВалюта) Тогда
				ЗаказОбъект.Валюта = НайденнаяВалюта;
			КонецЕсли;
		КонецЕсли;
		
		// Сумма документа
		СуммаСтрока = Строка(ДокументXDTO.Сумма);
		ЗаказОбъект.СуммаДокумента = Число(СуммаСтрока);
		
		// Комментарий
		КомментXDTO = ДокументXDTO.Свойства().Получить("Комментарий");
		Если КомментXDTO <> Неопределено Тогда
			ЗаказОбъект.Комментарий = Строка(ДокументXDTO.Комментарий);
		КонецЕсли;
		
		// Статус
		ЗаказОбъект.Статус = Перечисления.СтатусыЗаказовКлиентов.НеСогласован;
		
		// ═══ Заполнение табличной части Товары ═══
		ТоварыXDTO = ДокументXDTO.Свойства().Получить("Товары");
		Если ТоварыXDTO <> Неопределено Тогда
			Для Каждого СтрокаТоварыXDTO Из ДокументXDTO.Товары.Строка Цикл
				НоваяСтрока = ЗаказОбъект.Товары.Добавить();
				
				// Номенклатура
				ДанныеНоменклатуры = СтрокаТоварыXDTO.ДанныеНоменклатуры;
				НаименованиеНоменклатуры = Строка(ДанныеНоменклатуры.Наименование);
				НоваяСтрока.Номенклатура = НайтиИлиСоздатьНоменклатуру(НаименованиеНоменклатуры);
				
				// Количество
				НоваяСтрока.Количество = Число(СтрокаТоварыXDTO.Количество);
				
				// Цена
				НоваяСтрока.Цена = Число(СтрокаТоварыXDTO.Цена);
				
				// Сумма
				НоваяСтрока.Сумма = Число(СтрокаТоварыXDTO.Сумма);
				
				// СтавкаНДС
				СтавкаСтрока = Строка(СтрокаТоварыXDTO.СтавкаНДС);
				НоваяСтрока.СтавкаНДС = ОпределитьСтавкуНДС(СтавкаСтрока);
				
			КонецЦикла;
		КонецЕсли;
		
		// ═══ Проверка обязательных реквизитов ═══
		ЕстьОшибки = Ложь;
		
		Если Не ЗначениеЗаполнено(ЗаказОбъект.Организация) Тогда
			ДобавитьВЛог("ОШИБКА", "", "Обязательный реквизит: Организация не заполнена");
			ЕстьОшибки = Истина;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ЗаказОбъект.Контрагент) Тогда
			ДобавитьВЛог("ОШИБКА", "", "Обязательный реквизит: Контрагент не заполнен");
			ЕстьОшибки = Истина;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ЗаказОбъект.Валюта) Тогда
			// Авто-валюта: рубли
			Рубли = Справочники.Валюты.НайтиПоНаименованию("руб.");
			Если ЗначениеЗаполнено(Рубли) Тогда
				ЗаказОбъект.Валюта = Рубли;
			КонецЕсли;
		КонецЕсли;
		
		Если ЗаказОбъект.Товары.Количество() = 0 Тогда
			ДобавитьВЛог("ОШИБКА", "", "Нет строк в ТЧ Товары");
			ЕстьОшибки = Истина;
		КонецЕсли;
		
		Если ЗаказОбъект.СуммаДокумента = 0 Тогда
			ЗаказОбъект.СуммаДокумента = ЗаказОбъект.Товары.Итог("Сумма");
		КонецЕсли;
		
		Если ЕстьОшибки Тогда
			ОтменитьТранзакцию();
			ДобавитьВЛог("ПРОПУЩЕН", "", "Заказ пропущен из-за ошибок заполнения");
			Возврат;
		КонецЕсли;
		
		// ═══ Запись с проведением ═══
		ЗаказОбъект.Записать(РежимЗаписиДокумента.Проведение);
		
		ЗафиксироватьТранзакцию();
		
		ДобавитьВЛог("СОЗДАН", Строка(ЗаказОбъект.Ссылка), 
			СтрШаблон("Заказ %1 от %2 на сумму %3 (товаров: %4)",
			ЗаказОбъект.Номер, Формат(ЗаказОбъект.Дата, "ДФ=dd.MM.yyyy"),
			Формат(ЗаказОбъект.СуммаДокумента, "ЧДЦ=2; ЧГ=3,0"),
			ЗаказОбъект.Товары.Количество()));
		
	Исключение
		ОтменитьТранзакцию();
		ДобавитьВЛог("ОШИБКА", "", СтрШаблон("Ошибка: %1", ОписаниеОшибки()));
	КонецПопытки;
	
КонецПроцедуры

Функция НайтиИлиСоздатьНоменклатуру(Наименование)
	
	Если Не ЗначениеЗаполнено(Наименование) Тогда
		ДобавитьВЛог("ОШИБКА", "", "Номенклатура: пустое Наименование");
		Возврат Неопределено;
	КонецЕсли;
	
	Найденная = Справочники.Номенклатура.НайтиПоНаименованию(Наименование, Истина);
	Если ЗначениеЗаполнено(Найденная) Тогда
		Возврат Найденная;
	КонецЕсли;
	
	Попытка
		НовыйЭлемент = Справочники.Номенклатура.СоздатьЭлемент();
		НовыйЭлемент.Наименование = Наименование;
		НовыйЭлемент.НаименованиеПолное = Наименование;
		
		// Вид номенклатуры — ищем "Товары" или берём первый подходящий
		ВидТовары = Справочники.ВидыНоменклатуры.НайтиПоНаименованию("Товары");
		Если Не ЗначениеЗаполнено(ВидТовары) Тогда
			ВидТовары = Справочники.ВидыНоменклатуры.ВыбратьПервый();
			Если ВидТовары = Неопределено Тогда
				ДобавитьВЛог("ОШИБКА", "", "Нет вида номенклатуры в справочнике");
				Возврат Неопределено;
			КонецЕсли;
		КонецЕсли;
		НовыйЭлемент.ВидНоменклатуры = ВидТовары;
		
		// Заполнение реквизитов по виду номенклатуры (БСП паттерн)
		Справочники.Номенклатура.ЗаполнитьРеквизитыПоВидуНоменклатуры(НовыйЭлемент);
		
		// Единица измерения — шт по умолчанию
		ЕдиницаШт = Справочники.БазовыеЕдиницыИзмерения.НайтиПоНаименованию("шт");
		Если ЗначениеЗаполнено(ЕдиницаШт) Тогда
			НовыйЭлемент.ЕдиницаИзмерения = ЕдиницаШт;
		КонецЕсли;
		
		// Ставка НДС 20% по умолчанию
		НДС20 = Справочники.СтавкиНДС.НайтиПоРеквизиту("Ставка", 20);
		Если Не ЗначениеЗаполнено(НДС20) Тогда
			НДС20 = Справочники.СтавкиНДС.НДС20;
		КонецЕсли;
		НовыйЭлемент.СтавкаНДС = НДС20;
		
		// Проверка заполнения
		Если Не НовыйЭлемент.ПроверитьЗаполнение() Тогда
			ДобавитьВЛог("ОШИБКА", "", "Номенклатура: не прошла проверку заполнения");
			Возврат Неопределено;
		КонецЕсли;
		
		НовыйЭлемент.Записать();
		ДобавитьВЛог("СОЗДАН", "", "Номенклатура: " + Наименование);
		Возврат НовыйЭлемент.Ссылка;
	Исключение
		ДобавитьВЛог("ОШИБКА", "", "Не удалось создать номенклатуру: " + ОписаниеОшибки());
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

Функция ОпределитьСтавкуНДС(ЗначениеСтавки)
	
	Если Не ЗначениеЗаполнено(ЗначениеСтавки) Тогда
		Возврат Справочники.СтавкиНДС.БезНДС;
	КонецЕсли;
	
	ЗНРег = НРег(СокрЛП(ЗначениеСтавки));
	
	Если ЗНРег = "ндс20" Или ЗНРег = "20" Или ЗНРег = "20%" Тогда
		Возврат Справочники.СтавкиНДС.НДС20;
	ИначеЕсли ЗНРег = "ндс10" Или ЗНРег = "10" Или ЗНРег = "10%" Тогда
		Возврат Справочники.СтавкиНДС.НДС10;
	ИначеЕсли ЗНРег = "ндс0" Или ЗНРег = "0" Или ЗНРег = "0%" Тогда
		Возврат Справочники.СтавкиНДС.НДС0;
	Иначе
		Возврат Справочники.СтавкиНДС.БезНДС;
	КонецЕсли;
	
КонецФункции

Функция РазобратьURL(Знач URL)
	
	Результат = Новый Структура("Сервер, Порт, Путь", "", 80, "/");
	
	НРегURL = НРег(URL);
	Если СтрНачинаетсяС(НРегURL, "https://") Тогда
		URL = Сред(URL, 9);
	ИначеЕсли СтрНачинаетсяС(НРегURL, "http://") Тогда
		URL = Сред(URL, 8);
	КонецЕсли;
	
	ПозицияСлеша = СтрНайти(URL, "/");
	Если ПозицияСлеша > 0 Тогда
		Результат.Сервер = Лев(URL, ПозицияСлеша - 1);
		Результат.Путь = "/" + Сред(URL, ПозицияСлеша + 1);
	Иначе
		Результат.Сервер = URL;
	КонецЕсли;
	
	ПозицияДвоеточия = СтрНайти(Результат.Сервер, ":");
	Если ПозицияДвоеточия > 0 Тогда
		Результат.Порт = Число(Сред(Результат.Сервер, ПозицияДвоеточия + 1));
		Результат.Сервер = Лев(Результат.Сервер, ПозицияДвоеточия - 1);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#КонецЕсли
